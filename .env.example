# Copy to .env and set values. Each stack uses its own DATABASE_URL_* variable.
# Go server → DATABASE_URL_GO
# Python (python_db) → DATABASE_URL_PYTHON
# Express (express_db) → DATABASE_URL_EXPRESS
# Web (Next.js/Prisma) → DATABASE_URL_WEB (exposed as DATABASE_URL at runtime)

DATABASE_URL_GO=postgresql://postgres:postgres@localhost:5433/genghis
DATABASE_URL_PYTHON=postgresql://postgres:postgres@localhost:5434/genghis
DATABASE_URL_EXPRESS=postgresql://postgres:postgres@localhost:5435/genghis
DATABASE_URL_WEB=postgresql://postgres:postgres@localhost:5436/genghis

# Mapbox public token (https://account.mapbox.com)
NEXT_PUBLIC_MAPBOX_TOKEN=

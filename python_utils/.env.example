# PostgreSQL connection string used by SQLAlchemy sessions and Alembic migrations.
# psycopg v3 driver:
# postgresql+psycopg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg://transit_app:change_me@localhost:5432/transit_analytics

# Optional explicit URL for Alembic (if omitted, Alembic falls back to DATABASE_URL)
ALEMBIC_DATABASE_URL=postgresql+psycopg://transit_app:change_me@localhost:5432/transit_analytics

# SQLAlchemy logging toggle (0/1)
SQL_ECHO=0

# Runtime environment (optional)
APP_ENV=development